# Template for Config/auto_proxy.local (which is gitignored).
# Copy this file to `auto_proxy.local` and put the real proxy URLs in it.
# One proxy URL per line: http://user:password@host:port
# Blank lines and lines starting with '#' are ignored.
#
# If `auto_proxy.local` is absent, the build bakes an empty list and the
# auto-proxy feature simply stays inactive (the build does not fail).
http://USER:PASSWORD@HOST:PORT
http://USER:PASSWORD@HOST:PORT
